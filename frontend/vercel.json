{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/sistema-rifas/browser",
  "installCommand": "npm ci",
  "framework": null,
  "rewrites": [
    { "source": "/verify/:code", "destination": "https://rifas-nehd.onrender.com/v/:code" },

    { "source": "/(?:.+/)+(styles-[A-Z0-9]+\\.css)", "destination": "/$1" },
    { "source": "/(?:.+/)+(main-[A-Z0-9]+\\.js)", "destination": "/$1" },
    { "source": "/(?:.+/)+(chunk-[A-Z0-9]+\\.js)", "destination": "/$1" },
    { "source": "/(?:.+/)+(polyfills-[A-Z0-9]+\\.js)", "destination": "/$1" },
    { "source": "/(?:.+/)+(manifest\\.webmanifest)", "destination": "/$1" },
    { "source": "/(?:.+/)+(favicon\\.(?:svg|ico))", "destination": "/$1" },

    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*\\.(?:js|css|woff2?|jpg|jpeg|png|svg|webp|ico))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
