{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/sistema-rifas/browser",
  "installCommand": "npm ci",
  "framework": null,
  "rewrites": [
    { "source": "/verify/:code", "destination": "https://rifas-nehd.onrender.com/v/:code" },
    {
      "//comment": "Angular 21 builder inyecta <link href='styles-XXX.css'> ANTES del <base href='/'> y del <!doctype>. Al abrir rutas profundas (F5 en /admin/raffles/3), el browser pide el asset relativo a la ruta (/admin/raffles/styles-XXX.css) — que no existe. Este rewrite lo sirve desde raíz sin importar la ruta desde donde se pida. Aplica también a main-*.js, chunk-*.js, polyfills-*.js.",
      "source": "/(?:.*/)?(styles-[A-Z0-9]+\\.css|main-[A-Z0-9]+\\.js|chunk-[A-Z0-9]+\\.js|polyfills-[A-Z0-9]+\\.js|manifest\\.webmanifest|favicon\\.svg|favicon\\.ico)",
      "destination": "/$1"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*\\.(?:js|css|woff2?|jpg|jpeg|png|svg|webp|ico))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
