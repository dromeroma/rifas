# --- App ---
APP_NAME=sistema-rifas
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
FRONTEND_URL=http://localhost:4200

# --- Supabase ---
# Obtén estos valores en https://supabase.com/dashboard/project/<REF>/settings/
SUPABASE_PROJECT_REF=replace_me
SUPABASE_ACCESS_TOKEN=replace_me_personal_access_token
SUPABASE_URL=https://<REF>.supabase.co

# --- Database ---
# RUNTIME (FastAPI / asyncpg): Transaction pooler, puerto 6543.
# Panel: Project Settings → Database → Connection string → "Transaction pooler" (URI).
DATABASE_URL=postgresql+asyncpg://postgres.<REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres

# MIGRACIONES (Alembic): direct connection, puerto 5432. SIN pooling.
# Panel: Project Settings → Database → Connection string → "Direct connection".
ALEMBIC_DATABASE_URL=postgresql+asyncpg://postgres:<DB_PASSWORD>@db.<REF>.supabase.co:5432/postgres

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Security ---
JWT_SECRET_KEY=change_me_super_long_random_secret_at_least_64_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MIN=15
REFRESH_TOKEN_EXPIRES_DAYS=7
BCRYPT_ROUNDS=12

# --- CORS (CSV) ---
CORS_ORIGINS=http://localhost:4200,http://localhost:8080

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# --- Reservas ---
RESERVATION_HOURS=24
LOCK_DAYS_BEFORE_DRAW=7

# --- Emails (Resend) ---
# Si RESEND_ENABLED=false o no hay API key, los emails se omiten silenciosamente
# (la app sigue funcionando, simplemente no notifica).
#
# Cómo configurar:
#  1. https://resend.com → registra cuenta (gratis, 3000 emails/mes, 100/día)
#  2. API Keys → crear → copiar y pegar abajo
#  3. Para producción real: Domains → verifica tu dominio (5 min con DNS)
#     y cambia RESEND_FROM_EMAIL a algo como noreply@tudominio.com
#  4. Para testing: usa onboarding@resend.dev (Resend solo deja enviar al email
#     con el que te registraste mientras no verifiques dominio)
RESEND_ENABLED=false
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Sistema de Rifas
# Email que recibe alertas cuando hay pagos nuevos pendientes de revisar
ADMIN_NOTIFY_EMAIL=
