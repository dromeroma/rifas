# --- App ---
APP_NAME=sistema-rifas
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
FRONTEND_URL=http://localhost:4200

# --- Supabase ---
# Obtén estos valores en https://supabase.com/dashboard/project/<REF>/settings/
SUPABASE_PROJECT_REF=replace_me
SUPABASE_ACCESS_TOKEN=replace_me_personal_access_token
SUPABASE_URL=https://<REF>.supabase.co

# --- Database ---
# RUNTIME (FastAPI / asyncpg): Transaction pooler, puerto 6543.
# Panel: Project Settings → Database → Connection string → "Transaction pooler" (URI).
DATABASE_URL=postgresql+asyncpg://postgres.<REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres

# MIGRACIONES (Alembic): direct connection, puerto 5432. SIN pooling.
# Panel: Project Settings → Database → Connection string → "Direct connection".
ALEMBIC_DATABASE_URL=postgresql+asyncpg://postgres:<DB_PASSWORD>@db.<REF>.supabase.co:5432/postgres

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Security ---
JWT_SECRET_KEY=change_me_super_long_random_secret_at_least_64_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MIN=15
REFRESH_TOKEN_EXPIRES_DAYS=7
BCRYPT_ROUNDS=12

# --- CORS (CSV) ---
CORS_ORIGINS=http://localhost:4200,http://localhost:8080

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# --- Reservas ---
RESERVATION_HOURS=24
LOCK_DAYS_BEFORE_DRAW=7
